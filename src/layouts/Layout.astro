---
import '../styles/themes.css';
import '../styles/global.css';
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/600.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Hari - SWE',
	description = 'Software Engineer at Grab, Singapore. Building digital experiences, managing homelabs, and architecting cloud solutions.'
} = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />

		<!-- Standard favicons -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="data:image/png;base64," />
		<link rel="icon" type="image/png" sizes="16x16" href="data:image/png;base64," />

		<!-- Safari specific -->
		<link rel="mask-icon" href="/favicon.svg" color="#1e1e2e" />
		<link rel="apple-touch-icon" type="image/png" href="data:image/png;base64," />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="Hari - SWE" />

		<!-- Microsoft Edge & Windows -->
		<meta name="msapplication-TileColor" content="#1e1e2e" />
		<meta name="msapplication-config" content="none" />
		<meta name="application-name" content="Hari - SWE" />

		<!-- Open Graph / Social Media -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/favicon.svg" />

		<!-- PWA -->
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="theme-color" content="#1e1e2e" media="(prefers-color-scheme: dark)" />
		<meta name="theme-color" content="#eff1f5" media="(prefers-color-scheme: light)" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="color-scheme" content="dark light" />
		<!-- Prevent flash of wrong theme -->
		<script is:inline>
			(function() {
				const saved = localStorage.getItem('theme');
				if (saved) document.documentElement.setAttribute('data-theme', saved);
			})();
		</script>
	</head>
	<body>
		<slot />
	</body>
</html>
