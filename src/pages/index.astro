---
import Layout from '../layouts/Layout.astro';
import Terminal from '../components/Terminal.astro';
import Skills from '../components/Skills.astro';
import Projects from '../components/Projects.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
	<main class="container">
		<section class="hero">
			<div class="hero-content">
				<Terminal />
			</div>
		</section>

		<Skills />
		<Projects />
		<Contact />
		<Footer />
	</main>

	<style>
		.hero {
			min-height: 100vh;
			display: flex;
			align-items: center;
			justify-content: center;
			padding: 2rem 0;
		}

		.hero-content {
			max-width: 800px;
			width: 100%;
			position: relative;
		}

		@media (max-width: 768px) {
			.hero {
				min-height: 100vh;
				padding: 2rem 0;
			}
		}
	</style>

	<script>
		// Terminal typewriter effect
		function typeWriter(elementId: string, delay = 1000) {
			setTimeout(() => {
				const element = document.getElementById(elementId);
				if (element) element.classList.add('visible');
			}, delay);
		}

		// Apple-style dramatic scroll animations
		function revealSections() {
			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						setTimeout(() => {
							entry.target.classList.add('visible');
						}, 150);
					}
				});
			}, {
				threshold: 0.15,
				rootMargin: '0px 0px -120px 0px'
			});

			document.querySelectorAll('.hidden-section').forEach(section => {
				observer.observe(section);
			});
		}

		// Smooth scroll-based trigger
		function handleScroll() {
			const hero = document.querySelector('.hero');
			if (!hero) return;
			const heroHeight = hero.clientHeight;
			const scrollPosition = window.scrollY;
			const scrollProgress = Math.min(scrollPosition / (heroHeight * 0.6), 1);

			if (scrollProgress > 0.6) {
				document.querySelectorAll('.hidden-section').forEach((section, index) => {
					setTimeout(() => {
						section.classList.add('visible');
					}, index * 100);
				});
			}
		}

		document.addEventListener('DOMContentLoaded', () => {
			// Typing sequence
			typeWriter('greeting', 500);
			typeWriter('role', 1000);
			typeWriter('status', 1500);
			typeWriter('description', 2500);

			// Scroll detection
			revealSections();
			window.addEventListener('scroll', handleScroll);

			// Parallax effect for project cards (desktop only)
			if (window.innerWidth > 768) {
				function handleParallax() {
					const cards = document.querySelectorAll('.project-card');
					const scrollY = window.scrollY;
					const windowHeight = window.innerHeight;

					cards.forEach((card, index) => {
						const el = card as HTMLElement;
						const rect = el.getBoundingClientRect();

						if (rect.top < windowHeight && rect.bottom > 0 && el.classList.contains('visible')) {
							const speed = 0.02 + (index * 0.005);
							const yOffset = (scrollY - rect.top) * speed;
							el.dataset.parallaxY = String(yOffset);

							if (!el.matches(':hover')) {
								el.style.transform = `translateY(${yOffset}px) scale(1.005)`;
							}
						}
					});
				}

				window.addEventListener('scroll', handleParallax);
			}

			// Smooth scroll for view projects button
			const viewProjectsBtn = document.querySelector('a[href="#work"]');
			if (viewProjectsBtn) {
				const handleViewProjects = (e: Event) => {
					e.preventDefault();
					e.stopPropagation();
					const workSection = document.getElementById('work');
					if (workSection) {
						workSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
					}
				};

				viewProjectsBtn.addEventListener('click', handleViewProjects, { passive: false });
				viewProjectsBtn.addEventListener('touchend', handleViewProjects, { passive: false });
			}

			// Project link touch handling
			const projectLinks = document.querySelectorAll('.project-link');
			projectLinks.forEach(link => {
				link.addEventListener('click', () => {
					link.classList.add('touch-active');
					setTimeout(() => link.classList.remove('touch-active'), 300);
				});

				if ('ontouchstart' in window) {
					let touchStartTime = 0;
					let touchStartY = 0;

					link.addEventListener('touchstart', ((e: TouchEvent) => {
						touchStartTime = Date.now();
						touchStartY = e.touches[0].clientY;
					}) as EventListener, { passive: true });

					link.addEventListener('touchend', ((e: TouchEvent) => {
						const touchDuration = Date.now() - touchStartTime;
						const touchDistance = Math.abs(e.changedTouches[0].clientY - touchStartY);
						if (touchDuration < 300 && touchDistance < 10) {
							e.preventDefault();
							(link as HTMLElement).click();
						}
					}) as EventListener, { passive: false });
				}
			});

			// Resume button
			const resumeBtn = document.getElementById('resume-btn');
			const resumeTerminalBody = document.querySelector('.terminal-body');

			resumeBtn?.addEventListener('click', () => {
				document.documentElement.scrollTop = 0;
				document.body.scrollTop = 0;

				if (!resumeTerminalBody) return;

				resumeTerminalBody.querySelectorAll('.terminal-line').forEach(line => line.remove());
				resumeTerminalBody.querySelectorAll('.terminal-output').forEach(output => output.remove());

				const newCommandLine = document.createElement('div');
				newCommandLine.className = 'terminal-line';
				newCommandLine.innerHTML = `
					<span class="prompt">$</span>
					<span class="command">./get_resume.sh</span>
				`;
				resumeTerminalBody.appendChild(newCommandLine);

				setTimeout(() => {
					const output = document.createElement('div');
					output.className = 'terminal-output';
					output.innerHTML = `
						<div class="output-line" style="color: var(--accent-blue); opacity: 0;">Redirecting to Google Drive...</div>
						<div class="output-line" style="color: var(--accent-green); opacity: 0;">Opening resume document...</div>
					`;
					resumeTerminalBody.appendChild(output);

					const outputLines = output.querySelectorAll('.output-line');
					outputLines.forEach((line, index) => {
						setTimeout(() => {
							(line as HTMLElement).style.opacity = '1';
							(line as HTMLElement).style.animation = 'typewriter 0.5s ease-in';
						}, index * 800);
					});

					setTimeout(() => {
						const inputLine = document.createElement('div');
						inputLine.className = 'terminal-line';

						const promptSpan = document.createElement('span');
						promptSpan.className = 'prompt';
						promptSpan.textContent = '$ ';

						const newInput = document.createElement('input');
						newInput.type = 'text';
						newInput.className = 'terminal-input';
						newInput.spellcheck = false;
						newInput.autocomplete = 'off';
						newInput.style.cssText = `
							background: transparent !important;
							border: none !important;
							outline: none !important;
							color: var(--accent-green) !important;
							font-family: 'JetBrains Mono', monospace !important;
							font-size: 0.9rem !important;
							font-weight: 500 !important;
							padding: 0 !important;
							margin: 0 !important;
							box-shadow: none !important;
							-webkit-appearance: none !important;
							display: inline !important;
							width: calc(100% - 2rem) !important;
							line-height: 1.4 !important;
							vertical-align: baseline !important;
						`;

						inputLine.appendChild(promptSpan);
						inputLine.appendChild(newInput);
						resumeTerminalBody.appendChild(inputLine);
						newInput.focus();

						setTimeout(() => {
							window.open('https://drive.google.com/file/d/17trx9PnHUYck4NM9Eo-c9Rc1s1_BTQsT/view?usp=sharing', '_blank');
						}, 1500);
					}, 2000);
				}, 500);
			});

			// 3D tilt effect for project cards (desktop only)
			if (window.innerWidth > 768) {
				document.querySelectorAll('.project-card').forEach(card => {
					card.addEventListener('mousemove', (e) => {
						const el = card as HTMLElement;
						const rect = el.getBoundingClientRect();
						const me = e as MouseEvent;
						const x = me.clientX - rect.left;
						const y = me.clientY - rect.top;
						const centerX = rect.width / 2;
						const centerY = rect.height / 2;
						const rotateX = (y - centerY) / 10;
						const rotateY = (centerX - x) / 10;
						const parallaxY = el.dataset.parallaxY || '0';

						el.style.transform = `
							translateY(${parseFloat(parallaxY) - 8}px)
							scale(1.03)
							rotateX(${rotateX}deg)
							rotateY(${rotateY}deg)
						`;
					});

					card.addEventListener('mouseleave', () => {
						const el = card as HTMLElement;
						const parallaxY = el.dataset.parallaxY || '0';
						el.style.transform = `translateY(${parallaxY}px) scale(1.01)`;
					});
				});
			}

			// Touch interactions for project links (mobile only)
			if ('ontouchstart' in window) {
				document.querySelectorAll('.project-link').forEach(link => {
					link.addEventListener('touchstart', () => link.classList.add('touch-active'));
					link.addEventListener('touchend', () => {
						setTimeout(() => link.classList.remove('touch-active'), 300);
					});
					link.addEventListener('touchcancel', () => link.classList.remove('touch-active'));
				});
			}

			// Interactive Terminal
			const terminalInput = document.getElementById('terminal-input') as HTMLInputElement;
			const terminalHistory = document.getElementById('terminal-history');
			const terminalBody = document.getElementById('terminal-body');

			let commandHistory: string[] = [];
			let historyIndex = -1;

			function generateCalendar(month?: number, year?: number) {
				const now = new Date();
				const currentMonth = month ?? now.getMonth();
				const currentYear = year ?? now.getFullYear();

				const monthNames = [
					'January', 'February', 'March', 'April', 'May', 'June',
					'July', 'August', 'September', 'October', 'November', 'December'
				];

				const firstDay = new Date(currentYear, currentMonth, 1);
				const lastDay = new Date(currentYear, currentMonth + 1, 0);
				const daysInMonth = lastDay.getDate();
				const startingDayOfWeek = firstDay.getDay();

				let calendar = `      ${monthNames[currentMonth]} ${currentYear}\n`;
				calendar += 'Su Mo Tu We Th Fr Sa\n';

				let week = '';
				for (let i = 0; i < startingDayOfWeek; i++) {
					week += '   ';
				}

				for (let day = 1; day <= daysInMonth; day++) {
					const dayStr = day.toString().padStart(2, ' ');

					if (currentYear === now.getFullYear() &&
						currentMonth === now.getMonth() &&
						day === now.getDate()) {
						week += `<span style="background: var(--accent-blue); color: var(--bg-primary); border-radius: 2px; padding: 0 1px; font-weight: 600;">${dayStr}</span>`;
					} else {
						week += dayStr;
					}

					if ((startingDayOfWeek + day) % 7 === 0) {
						calendar += week + '\n';
						week = '';
					} else {
						week += ' ';
					}
				}

				if (week.trim()) {
					calendar += week + '\n';
				}

				return calendar;
			}

			const commands: Record<string, (args: string[]) => string | Promise<string>> = {
				cal: (args) => {
					if (args.length === 0) return generateCalendar();
					if (args.length === 1) {
						const year = parseInt(args[0]);
						if (isNaN(year)) return 'cal: invalid year';
						return generateCalendar(new Date().getMonth(), year);
					}
					if (args.length === 2) {
						const month = parseInt(args[0]) - 1;
						const year = parseInt(args[1]);
						if (isNaN(month) || isNaN(year) || month < 0 || month > 11) return 'cal: invalid month or year';
						return generateCalendar(month, year);
					}
					return 'cal: too many arguments';
				},

				ls: (args) => {
					if (args.includes('-la') || args.includes('-l')) {
						return `drwxr-xr-x  5 hari  staff   160 Jan 15 2025 .
drwxr-xr-x  3 hari  staff    96 Jan 10 2025 ..
drwxr-xr-x  1 hari  staff  2048 Jan 15 2025 portfolio/
drwxr-xr-x  1 hari  staff  4096 Jan 12 2025 moneyfly/
drwxr-xr-x  1 hari  staff  1024 Dec 28 2024 proxmox-paradise/
drwxr-xr-x  1 hari  staff   512 Nov 15 2020 simphony/`;
					}
					return 'portfolio  moneyfly  proxmox-paradise  simphony';
				},

				echo: (args) => args.join(' '),

				cat: (args) => {
					const file = args[0];
					if (!file) return 'cat: missing file operand';
					if (file === './about.txt' || file === 'about.txt') {
						return `When I'm not deploying to the cloud, I'm deploying to my homelab.\nBuilding the boring stuff that makes the exciting stuff possible.`;
					}
					if (file === './projects.txt' || file === 'projects.txt') {
						return `portfolio/          - This very website (Astro + Cursor ✨)\nmoneyfly/           - Flutter expense tracker & airline miles optimizer\nproxmox-paradise/   - Self-hosted data center setup\nsimphony/           - Mobile flight simulation controls`;
					}
					return `cat: ${file}: No such file or directory`;
				},

				whoami: async () => {
					const ua = navigator.userAgent;
					const platform = navigator.platform;
					const language = navigator.language;
					const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone;
					const screen = `${window.screen.width}x${window.screen.height}`;

					let browser = 'Unknown';
					if (ua.includes('Chrome') && !ua.includes('Edge')) browser = 'Chrome';
					else if (ua.includes('Firefox')) browser = 'Firefox';
					else if (ua.includes('Safari') && !ua.includes('Chrome')) browser = 'Safari';
					else if (ua.includes('Edge')) browser = 'Edge';

					const isMobile = /Android|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(ua);
					const deviceType = isMobile ? 'Mobile' : 'Desktop';

					let result = `user: unknown\ndevice: ${deviceType}\nbrowser: ${browser}\nplatform: ${platform}\nlanguage: ${language}\ntimezone: ${timezone}\nscreen: ${screen}`;

					try {
						const response = await fetch('https://api.ipify.org?format=json');
						const data = await response.json();
						result += `\nip: ${data.ip}`;
					} catch {
						result += '\nip: unavailable';
					}

					return result;
				},

				pwd: () => '/Users/hari/portfolio',
				date: () => new Date().toString(),

				uname: (args) => {
					if (args.includes('-a')) return 'Darwin Haris-MacBook 24.5.0 Darwin Kernel Version 24.5.0 arm64';
					return 'Darwin';
				},

				clear: () => {
					if (terminalHistory) terminalHistory.innerHTML = '';
					return '';
				},

				rm: (args) => {
					if (args.length >= 2 && args[0] === '-rf' && args[1] === '/') {
						setTimeout(() => {
							if (!terminalHistory || !terminalBody) return;
							terminalHistory.innerHTML = '';

							const deletionMessages = [
								'rm: removing directory `/usr`',
								'rm: removing directory `/var`',
								'rm: removing directory `/home`',
								'rm: removing directory `/etc`',
								'rm: removing directory `/boot`',
								'rm: removing directory `/sys`',
								'rm: removing directory `/proc`',
								'rm: cannot remove `/`: Device or resource busy'
							];

							let messageIndex = 0;
							const showNextMessage = () => {
								if (messageIndex < deletionMessages.length) {
									const msgDiv = document.createElement('div');
									msgDiv.className = 'terminal-output';
									msgDiv.innerHTML = `<div class="output-line" style="color: var(--text-primary)">${deletionMessages[messageIndex]}</div>`;
									terminalHistory.appendChild(msgDiv);
									terminalBody.scrollTop = terminalBody.scrollHeight;
									messageIndex++;

									if (messageIndex < deletionMessages.length) {
										setTimeout(showNextMessage, 200);
									} else {
										setTimeout(() => {
											window.location.href = '/404';
										}, 1000);
									}
								}
							};

							showNextMessage();
						}, 100);
						return '';
					}
					return `rm: missing operand or invalid arguments\nTry 'rm --help' for more information.`;
				},

				help: () => {
					return `Available commands:
  cal [month] [year] - Display calendar (try just 'cal')
  ls [-la]          - List directory contents
  cat <file>        - Display file contents (try 'about.txt')
  echo <text>       - Display text
  pwd               - Print working directory
  whoami            - Display user & system information
  date              - Display current date
  uname [-a]        - Display system information
  clear             - Clear terminal history
  help              - Show this help message

Pro tip: Use ↑/↓ arrows to navigate command history!`;
				}
			};

			async function executeCommand(input: string) {
				const trimmed = input.trim();
				if (!trimmed) return '';
				const [command, ...args] = trimmed.split(' ');
				if (commands[command]) {
					const result = commands[command](args);
					if (result instanceof Promise) return await result;
					return result;
				}
				return `${command}: command not found`;
			}

			function addToHistory(command: string, output: string) {
				if (!terminalHistory || !terminalBody) return;

				const commandLine = document.createElement('div');
				commandLine.className = 'terminal-line';
				commandLine.innerHTML = `
					<span class="prompt">$</span>
					<span class="command">${command}</span>
				`;
				terminalHistory.appendChild(commandLine);

				if (output.trim()) {
					const outputDiv = document.createElement('div');
					outputDiv.className = 'terminal-output';
					const lines = output.split('\n');
					outputDiv.innerHTML = lines.map(line =>
						`<div class="output-line">${line}</div>`
					).join('');
					terminalHistory.appendChild(outputDiv);
				}

				const newInputLine = document.createElement('div');
				newInputLine.className = 'terminal-line';

				const promptSpan = document.createElement('span');
				promptSpan.className = 'prompt';
				promptSpan.textContent = '$ ';

				const newInput = document.createElement('input');
				newInput.type = 'text';
				newInput.className = 'terminal-input';
				newInput.spellcheck = false;
				newInput.autocomplete = 'off';
				newInput.style.cssText = `
					background: transparent !important;
					border: none !important;
					outline: none !important;
					color: var(--accent-green) !important;
					font-family: 'JetBrains Mono', monospace !important;
					font-size: 0.9rem !important;
					font-weight: 500 !important;
					padding: 0 !important;
					margin: 0 !important;
					box-shadow: none !important;
					-webkit-appearance: none !important;
					display: inline !important;
					width: calc(100% - 2rem) !important;
					line-height: 1.4 !important;
					vertical-align: baseline !important;
				`;

				newInputLine.appendChild(promptSpan);
				newInputLine.appendChild(newInput);
				terminalHistory.appendChild(newInputLine);

				setTimeout(() => newInput.focus(), 100);
				terminalBody.scrollTop = terminalBody.scrollHeight;
			}

			// Handle terminal input (delegated)
			terminalBody?.addEventListener('keydown', async (e) => {
				const target = e.target as HTMLInputElement;
				if (!target.classList.contains('terminal-input')) return;

				if (e.key === 'Enter') {
					e.preventDefault();
					const command = target.value;
					const output = await executeCommand(command);

					if (command.trim()) {
						commandHistory.push(command);
						historyIndex = commandHistory.length;
					}

					const currentLine = target.closest('.terminal-line');
					if (currentLine) currentLine.remove();

					addToHistory(command, output);
				} else if (e.key === 'ArrowUp') {
					e.preventDefault();
					if (historyIndex > 0) {
						historyIndex--;
						target.value = commandHistory[historyIndex];
					}
				} else if (e.key === 'ArrowDown') {
					e.preventDefault();
					if (historyIndex < commandHistory.length - 1) {
						historyIndex++;
						target.value = commandHistory[historyIndex];
					} else {
						historyIndex = commandHistory.length;
						target.value = '';
					}
				}
			});

			// Focus management
			terminalBody?.addEventListener('focus', (e) => {
				const target = e.target as HTMLElement;
				if (target.classList.contains('terminal-input')) target.select();
			}, true);

			terminalBody?.addEventListener('click', () => {
				const lastInput = terminalBody.querySelector('.terminal-input:last-of-type') as HTMLInputElement;
				if (lastInput) lastInput.focus();
			});

			// Show prompt bubble
			let promptShown = false;
			const showPromptOnFocus = () => {
				if (promptShown) return;
				const terminalPrompt = document.getElementById('terminal-prompt');
				if (terminalPrompt) {
					terminalPrompt.classList.add('show');
					promptShown = true;
					setTimeout(() => {
						if (terminalPrompt.classList.contains('show')) {
							terminalPrompt.classList.remove('show');
						}
					}, 10000);
				}
			};

			terminalBody?.addEventListener('focus', (e) => {
				if ((e.target as HTMLElement).classList.contains('terminal-input')) showPromptOnFocus();
			}, true);

			terminalBody?.addEventListener('click', (e) => {
				if ((e.target as HTMLElement).classList.contains('terminal-input')) showPromptOnFocus();
			});

			// Focus initial input after animations
			setTimeout(() => {
				const initialInput = document.getElementById('terminal-input') as HTMLInputElement;
				if (initialInput) {
					initialInput.value = '';
					initialInput.focus();
				}
			}, 3000);

			// Prompt close button
			const promptClose = document.getElementById('prompt-close');
			const terminalPrompt = document.getElementById('terminal-prompt');
			if (promptClose && terminalPrompt) {
				promptClose.addEventListener('click', () => {
					terminalPrompt.classList.remove('show');
				});
			}
		});
	</script>
</Layout>
