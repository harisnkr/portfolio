<footer class="footer">
	<div class="footer-row">
		<span class="visits" id="visit-counter" aria-live="polite"></span>
		<span class="sep" id="footer-sep" aria-hidden="true">|</span>
		<span class="copyright">&copy; 2026 Hari.</span>
	</div>
</footer>

<style>
	.footer {
		padding: 1.5rem 0;
		border-top: 1px solid var(--border-color);
		text-align: center;
	}

	.footer-row {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.6rem;
		flex-wrap: wrap;
	}

	.footer-row span {
		color: var(--text-muted);
		font-size: 0.9rem;
		font-family: 'JetBrains Mono', monospace;
	}

	.visits,
	.sep {
		font-size: 0.8rem;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.visits.visible,
	.sep.visible {
		opacity: 1;
	}
</style>

<script>
	(async () => {
		const el = document.getElementById('visit-counter');
		const sep = document.getElementById('footer-sep');
		if (!el) return;
		try {
			const res = await fetch('/api/visits');
			const data = await res.json();
			if (typeof data.count === 'number') {
				el.textContent = `visits: ${data.count.toLocaleString()}`;
				el.classList.add('visible');
				sep?.classList.add('visible');
			}
		} catch {
			// Silently skip — counter is decorative, not critical.
		}
	})();
</script>
